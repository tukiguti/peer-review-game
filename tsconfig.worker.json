{
  // Worker(Durable Object)側の型チェック専用。DOM ではなく Cloudflare Workers の型を使う。
  // include は src/server のみ。import された draw/scoring/types/protocol は自動的に検査対象になる
  //（reducer/audio など DOM 依存モジュールは import しないので混入しない）。
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["@cloudflare/workers-types"],
    "resolveJsonModule": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src/server"]
}
